{
  "name": "rlr-p2p-chat",
  "version": "3.2.2",
  "description": "Two-User Encrypted P2P Desktop Chat App",
  "main": "dist-electron/main/index.js",
  "author": "RLRJupiter & Ripster",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --config electron-builder.yml",
    "build:portable": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable --config electron-builder.yml",
    "build:nsis": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis --config electron-builder.yml",
    "build:all": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --config electron-builder.yml",
    "package": "electron-builder --win --config electron-builder.yml",
    "clean": "rm -rf dist-electron out release",
    "clean-cache": "node scripts/fix-winsign-cache.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:verbose": "jest --verbose"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "say": "^0.16.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.24",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "canvas": "^3.2.0",
    "electron": "^21.4.4",
    "electron-builder": "^24.9.1",
    "electron-vite": "^4.0.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "playwright": "^1.56.1",
    "png-to-ico": "^3.0.1",
    "ts-jest": "^29.4.5",
    "typescript": "^5.3.3",
    "vite": "^7.1.12"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.52.5"
  }
}
